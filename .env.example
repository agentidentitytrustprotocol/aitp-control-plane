# Server
PORT=4000
CP_BASE_URL=http://localhost:4000

# CP identity — REQUIRED in production. Generate:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CP_AID_SEED_HEX=

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aitp_control_plane
DB_POOL_MAX=20

# API key list (comma-separated). Empty = auth disabled.
# REQUIRED in production (NODE_ENV=production) — admin endpoints like
# /api/webhooks, /api/audit, and DELETE /api/registry/agents/:aid will
# 503 if this is unset in prod, to prevent accidental public exposure.
API_KEYS=

# Enrollment token signing secret (REQUIRED). Generate:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENROLLMENT_SECRET=

# CORS origin — REQUIRED in production. Set to the UI plane origin.
# Falls back to "*" with a warning if unset on NODE_ENV=production.
CORS_ORIGIN=http://localhost:3000

# ── Multi-tenancy note ───────────────────────────────────────────────
# `GET /api/registry/agents` without `?namespace=` returns rows across
# ALL namespaces by design (registry discovery is an operational,
# non-normative layer in AITP — not a protocol isolation boundary). If you
# rely on per-tenant isolation, your caller MUST set
# `?namespace=<tenant>` on discovery and `X-Aitp-Namespace: <tenant>`
# on enrollment. The CP enforces no implicit tenancy boundary.

# Revocation list TTL (seconds)
REVOCATION_LIST_TTL_SECS=3600

# Webhook retry attempts (per delivery)
WEBHOOK_RETRY_ATTEMPTS=3

# Optional SSRF allowlist for webhook target hosts. Comma-separated.
# Empty = any PUBLIC host is allowed (private/loopback/link-local ranges
# are always rejected). An entry beginning with "." matches the apex and
# any subdomain (e.g. ".example.com" matches example.com and a.example.com).
# WEBHOOK_URL_ALLOWLIST=.hooks.example.com,events.partner.com

# SSE backlog size (in-memory)
MAX_AUDIT_EVENTS_MEMORY=500

# Maximum concurrent /api/events/stream connections per process.
# 503 SSE_CAPACITY is returned above this; clients should back off and retry.
MAX_SSE_CONNECTIONS=500

# Logging
LOG_LEVEL=info

# ── OpenTelemetry (disabled by default) ──────────────────────────────
# Set OTEL_ENABLED=true to enable. Spans are exported to the OTLP HTTP
# endpoint at OTEL_EXPORTER_OTLP_ENDPOINT (path /v1/traces is appended
# unless OTEL_EXPORTER_OTLP_TRACES_ENDPOINT is set explicitly).
# Auto-instruments HTTP, pg, fetch, etc.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=aitp-control-plane
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── Rate limiting (requests per minute, in-memory per-process) ───────
# Set any limit to 0 to disable that bucket. Set RATE_LIMIT_ENABLED=false
# to disable the limiter entirely (useful in dev / load tests).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ENROLLMENT_PER_IP_MIN=5
RATE_LIMIT_PUBLIC_PER_IP_MIN=60
RATE_LIMIT_API_KEY_PER_MIN=600
# Window over which the per-min limits accumulate. Default 60s matches the
# bucket-name "per-min" semantics; bump to e.g. 5m for smoother averaging.
RATE_LIMIT_WINDOW_MS=60000
# Client-IP resolution for rate limiting. X-Forwarded-For is
# client-controllable, so by default (TRUSTED_PROXY_HOPS=0) it is NOT
# trusted — set these to match your edge or per-IP limits are spoofable.
#   CLIENT_IP_HEADER: a single trusted header your edge sets to the real
#     client IP. Takes precedence when set.
#   TRUSTED_PROXY_HOPS: number of trusted proxies appending to XFF; the
#     client IP is read that many entries from the RIGHT of the header.
# CLIENT_IP_HEADER=x-vercel-forwarded-for
TRUSTED_PROXY_HOPS=0

# ── Data retention sweep ─────────────────────────────────────────────
# Periodically deletes old audit events, terminal webhook deliveries,
# admin audit log entries, and long-deregistered agents. Multi-instance
# safe via a Postgres advisory lock. Set any TTL to 0 to keep that
# table indefinitely.
RETENTION_ENABLED=true
RETENTION_INTERVAL_MS=1800000
AUDIT_EVENTS_TTL_DAYS=90
WEBHOOK_DELIVERY_TTL_DAYS=14
EXPIRED_AGENT_GRACE_DAYS=30
ADMIN_AUDIT_TTL_DAYS=365
IDEMPOTENCY_KEY_TTL_DAYS=7
RETENTION_BATCH_LIMIT=10000
